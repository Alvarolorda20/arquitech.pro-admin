# Shared environment template for admin stack
# Copy to `.env` in repo root before deploy.

# --- Supabase (shared) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Admin frontend (panel-admin) ---
NEXT_PUBLIC_API_URL=https://api-admin.arquitech.pro
NEXT_PUBLIC_BACKEND_URL=https://api-admin.arquitech.pro
API_URL=https://api-admin.arquitech.pro

NEXT_PUBLIC_ADMIN_APP_URL=https://admin.arquitech.pro
ADMIN_APP_URL=https://admin.arquitech.pro
ADMIN_PANEL_HOST=admin.arquitech.pro
ADMIN_API_HOST=api-admin.arquitech.pro

NEXT_PUBLIC_WORKSPACE_APP_URL=https://app.arquitech.pro
WORKSPACE_APP_URL=https://app.arquitech.pro
WORKSPACE_APP_HOST=app.arquitech.pro

# --- Admin backend (backend-admin) ---
# Production hardening: never use localhost/127.0.0.1/0.0.0.0 here.
BACKEND_CORS_ORIGINS=https://admin.arquitech.pro
UVICORN_WORKERS=2
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Global admin hardening (required in prod) ---
GLOBAL_ADMIN_USER_IDS=
GLOBAL_ADMIN_EMAILS=
GLOBAL_ADMIN_ALLOWED_ROLES=global_admin,super_admin
GLOBAL_ADMIN_METADATA_FLAGS=global_admin,is_global_admin
